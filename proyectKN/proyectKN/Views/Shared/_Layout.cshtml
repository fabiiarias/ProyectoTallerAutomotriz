<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">


    <title>@ViewBag.Title - Taller La Unión</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet" />

    <!-- Soft UI Dashboard CSS -->   
    <link href="~/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/main.css" rel="stylesheet" />
    <link href="~/css/cards.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/css/FileName.css" rel="stylesheet" />

    @* <link href="~/css/fondo.css" rel="stylesheet" /> *@
    <link rel="shortcut icon" href="~/lib/img/favicon.png" />

</head>

<body class="g-sidenav-show bg-gray-100 d-flex flex-column min-vh-100">

    <header id="header" class="header dark-background d-flex flex-column">
        <i class="header-toggle d-xl-none bi bi-list"></i>

        <a asp-controller="Home" asp-action="Index" class="logo d-flex align-items-center justify-content-center">
            <h1 class="sitename">Taller la Unión</h1>
        </a>

        <nav id="navmenu" class="navmenu">
            <ul>
                <li><a asp-controller="Home" asp-action="Index" class="active"> <i class="bi bi-house-door-fill navicon"></i> Inicio</a></li>
                <li><a asp-controller="Usuario" asp-action="RegistroUsuario"><i class="bi bi-people-fill navicon"></i>Gestión Usuarios</a></li>
                <li><a asp-controller="Cita" asp-action="RegistroCita"><i class="bi bi-calendar-check-fill navicon"></i> Citas</a></li>
                <li><a asp-controller ="Inventario" asp-action="Registro"><i class="bi bi-box-seam-fill navicon"></i> Inventario</a></li>
                <li><a asp-controller="Vehiculo" asp-action="RegistroVehiculo"><i class="bi bi-car-front-fill navicon"></i> Gestión de Vehículos</a></li>

                <li class="dropdown">
                    <a href="#">
                        <i class="bi bi-menu-button navicon"></i>
                        <span>Contabilidad</span>
                        <i class="bi bi-chevron-down toggle-dropdown"></i>
                    </a>

                    <ul class="dropdown-menu">
                        <li>
                            <a asp-controller="Contavilidad" asp-action="RegistroEgreso">
                                <i class="bi bi-arrow-down-circle-fill me-2"></i>
                                Egresos
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Contavilidad" asp-action="RegistroIngreso">
                                <i class="bi bi-arrow-up-circle-fill me-2"></i>
                                Ingresos
                            </a>
                        </li>
                    </ul>
                </li>

                <li>
                    <a href="#contact">
                        <i class="bi bi-bar-chart-fill navicon"></i>
                        Reportes
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <div class="main-content-adjust">
        <div class="container pb-4">
            @RenderBody()
        </div>
    </div>
    <!-- footer -->
    <footer class="footer py-4 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center">
                    <p class="mb-0 text-secondary">
                        © <script>document.write(new Date().getFullYear())</script> Taller La Unión
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!--JS -->
 <script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/js/main.js"></script>

</body>
</html>