
@{
    ViewData["Title"] = "RegistroIngreso";
}

<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- CSS -->
    <link rel="stylesheet" href="~/css/cards.css" />
</head>

<body>

    <div class="container mt-4">

        <!-- Header flotante -->
        <div class="profile-header">
            <h2>Registro de Ingreso</h2>
            <p>Registrar un nuevo Ingreso</p>
        </div>

        <!-- FORMULARIO -->
        <div class="card">
            <form asp-action="RegistroIngreso"
                  asp-controller="Contabilidad"
                  method="post"
                  class="card-body">

                <div class="row">
                    <div class="field">
                        <label>Motivo del ingreso</label>
                        <input type="text">
                    </div>

                    <div class="field">
                        <label>Pago</label>
                        <select name="estado" required>
                            <option value="Recibido">Completo</option>
                            <option value="Pendiente">Parcial</option>
                            <option value="Pendiente">Pendiente</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="field">
                        <label>Monto</label>
                        <input type="number">
                    </div>

                    <div class="field">
                        <label>Deuda(₡)</label>
                        <input type="number">
                    </div>

                </div>

                <button type="submit" class="btn">Crear</button>

            </form>
        </div>

        <!-- TABLA -->
        <div class="table-registros">
            <div class="table-title">Ingresos Registrados</div>

            <table>
                <thead>
                    <tr>
                        <th>Motivo del ingreso</th>
                        <th>Monto</th>
                        <th>Pago</th>
                        <th>Deuda</th>
                        <th>Fecha de registro</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Marca</td>
                                <td>@item.Placa</td>
                                <td>@item.Anio</td>
                                <td>@item.Estado</td>
                                <td>@item.Problema</td>
                                <td>@item.NombreCliente</td>

                                <td>


                                    <a asp-controller="Contavilidad"
                                       asp-action="Editar"
                                       asp-route-id="@item.IdVehiculo"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Eliminar"
                                       asp-route-id="@item.IdVehiculo"
                                       class="btn btn-danger btn-sm">
                                        Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted text-white">
                                No hay productos registrados
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <!-- JS -->
</body>
